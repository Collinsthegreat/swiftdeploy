# Generated by swiftdeploy init - DO NOT EDIT MANUALLY
# Edit manifest.yaml and run: ./swiftdeploy init

version: "3.9"

networks:
  {{ network.name }}:
    driver: {{ network.driver_type }}
  opa-internal:
    driver: bridge
    internal: true
  opa-host-access:
    driver: bridge

volumes:
  {{ services.log_volume }}:

services:
  {{ services.name }}:
    image: {{ services.image }}
    restart: {{ services.restart_policy }}
    networks:
      - {{ network.name }}
    environment:
      MODE: {{ services.mode }}
      APP_VERSION: "{{ services.version }}"
      APP_PORT: "{{ services.port }}"
    volumes:
      - {{ services.log_volume }}:/app/logs
    user: "1001:1001"
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:{{ services.port }}{{ services.healthcheck_path }}"]
      interval: {{ services.healthcheck_interval }}
      timeout: {{ services.healthcheck_timeout }}
      retries: {{ services.healthcheck_retries }}
      start_period: 15s
    # Service port is NEVER exposed - all traffic goes through Nginx only

  nginx:
    image: {{ nginx.image }}
    restart: {{ services.restart_policy }}
    networks:
      - {{ network.name }}
    ports:
      - "{{ nginx.port }}:{{ nginx.port }}"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - {{ services.log_volume }}:/var/log/nginx
    depends_on:
      {{ services.name }}:
        condition: service_healthy
    user: "101:101"
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:{{ nginx.port }}/healthz"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s

  opa:
    image: {{ opa.image }}
    restart: {{ services.restart_policy }}
    networks:
      - opa-internal
      - opa-host-access
    environment:
      OPA_DOCKER_IMAGE_TAG: ""
    ports:
      - "127.0.0.1:{{ opa.port }}:{{ opa.port }}"
    volumes:
      - {{ opa.policies_dir }}:/policies:ro
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    command:
      - "run"
      - "--server"
      - "--addr=0.0.0.0:{{ opa.port }}"
      - "--log-level=error"
      - "/policies"
    healthcheck:
      test: ["CMD", "/opa", "eval", "true"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 10s
