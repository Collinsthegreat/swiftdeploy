# Generated by swiftdeploy init - DO NOT EDIT MANUALLY
# Edit manifest.yaml and run: ./swiftdeploy init

worker_processes auto;
error_log /var/log/nginx/error.log warn;
pid /tmp/nginx.pid;

events {
    worker_connections 1024;
}

http {
    client_body_temp_path /tmp/client_temp;
    proxy_temp_path /tmp/proxy_temp;
    fastcgi_temp_path /tmp/fastcgi_temp;
    uwsgi_temp_path /tmp/uwsgi_temp;
    scgi_temp_path /tmp/scgi_temp;

    # Access log format
    log_format swiftdeploy '$time_iso8601 | $status | ${request_time}s | $upstream_addr | $request';
    access_log {{ nginx.access_log }} swiftdeploy;

    # Upstream service
    upstream swiftdeploy_backend {
        server {{ services.name }}:{{ services.port }};
        keepalive 32;
    }

    # Proxy timeouts
    proxy_connect_timeout {{ nginx.proxy_timeout }};
    proxy_send_timeout    {{ nginx.proxy_timeout }};
    proxy_read_timeout    {{ nginx.proxy_timeout }};
    proxy_intercept_errors on;

    server {
        listen {{ nginx.port }};
        server_name _;

        # Add swiftdeploy header to all responses
        add_header X-Deployed-By "swiftdeploy" always;

        # Forward X-Mode from upstream
        proxy_pass_header X-Mode;

        # JSON error bodies for gateway errors
        error_page 502 @json_502;
        error_page 503 @json_503;
        error_page 504 @json_504;

        location @json_502 {
            internal;
            default_type application/json;
            add_header X-Deployed-By "swiftdeploy" always;
            return 502 '{"error":"Bad Gateway","code":502,"service":"{{ services.name }}","contact":"ops@swiftdeploy.io"}';
        }

        location @json_503 {
            internal;
            default_type application/json;
            add_header X-Deployed-By "swiftdeploy" always;
            return 503 '{"error":"Service Unavailable","code":503,"service":"{{ services.name }}","contact":"ops@swiftdeploy.io"}';
        }

        location @json_504 {
            internal;
            default_type application/json;
            add_header X-Deployed-By "swiftdeploy" always;
            return 504 '{"error":"Gateway Timeout","code":504,"service":"{{ services.name }}","contact":"ops@swiftdeploy.io"}';
        }

        # Health check endpoint - direct proxy
        location /healthz {
            proxy_pass http://swiftdeploy_backend;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # All traffic routes through Nginx to backend
        location / {
            proxy_pass http://swiftdeploy_backend;
            proxy_http_version 1.1;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            proxy_set_header Connection "";
        }
    }
}
